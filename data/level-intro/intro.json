[
   { "at": 0.0, "action": "set_hud_visible",     "visible": false },
   { "at": 0.0, "action": "set_player_visible",  "visible": false },
   { "at": 0.0, "action": "set_camera_position", "x": 200, "y": 200 },
   { "at": 0.0, "action": "create_sprite",        "name": "player_left",  "animation": "player_run_r", "animation_file": "data/sprites/animations.json", "looped": true, "x": -200, "y": 200 },
   { "at": 0.0, "action": "create_sprite",        "name": "player_right", "animation": "player_run_l", "animation_file": "data/sprites/animations.json", "looped": true, "x": 600,  "y": 200 },
   { "at": 0.0, "action": "fade_in",              "speed": 1.0 },

   { "at": 1.5, "action": "move_sprite", "name": "player_left", "x": 170, "y": 200, "speed": 80, "event": "player_left_arrived" },

   { "on": "player_left_arrived",               "action": "set_sprite_animation", "name": "player_left",  "animation": "player_idle_r", "looped": true },
   { "on": "player_left_arrived", "delay": 0.5, "action": "move_sprite",           "name": "player_right", "x": 230, "y": 200, "speed": 80, "event": "player_right_arrived" },

   { "on": "player_right_arrived",               "action": "set_sprite_animation", "name": "player_right", "animation": "player_idle_l", "looped": true },
   { "on": "player_right_arrived", "delay": 1.0, "action": "show_dialogue",        "id": "intro_chat" },

   { "on": "intro_chat/dismissed", "delay": 0.5, "action": "set_sprite_animation", "name": "player_left", "animation": "player_run_l", "looped": true },
   { "on": "intro_chat/dismissed", "delay": 0.5, "action": "move_sprite",           "name": "player_left", "x": -200, "y": 200, "speed": 80, "event": "player_left_exited" },

   { "on": "player_left_exited", "action": "set_sprite_animation", "name": "player_right", "animation": "player_run_r", "looped": true },
   { "on": "player_left_exited", "action": "move_sprite",           "name": "player_right", "x": 600,  "y": 200, "speed": 80, "event": "player_right_exited" },

   { "on": "player_right_exited", "delay": 0.3, "action": "fade_out", "speed": 1.0 },

   { "on": "fade/out_done", "action": "destroy_sprite", "name": "player_left" },
   { "on": "fade/out_done", "action": "destroy_sprite", "name": "player_right" },
   { "on": "fade/out_done", "action": "next_level" }
]
