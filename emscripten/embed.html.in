<!doctype html>
<html lang="en-us">
<head>
    <meta charset="utf-8">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <title>VRSFML demo (embed)</title>

    <!--
        Minimal canvas-only wrapper for iframing into other pages.
        Generated by `stage_emcc_rel_examples.sh` from this template by
        substituting `@SFML_EMBED_JS@` with the per-example .js filename.
        The corresponding .wasm is fetched by that .js automatically.
    -->

    <script src="coi-serviceworker.js"></script>

    <style>
        html, body {
            margin: 0;
            padding: 0;
            height: 100%;
            width: 100%;
            background: #000;
            overflow: hidden;
        }
        body {
            display: flex;
            align-items: center;
            justify-content: center;
        }
        canvas#canvas {
            display: block;
            background: #000;
            border: 0;
            outline: none;
        }
    </style>
</head>
<body>
    <canvas id="canvas" oncontextmenu="event.preventDefault()" tabindex="-1"></canvas>

    <script type="text/javascript">
        var Module = {
            canvas: (() => {
                var c = document.getElementById('canvas');
                c.addEventListener('webglcontextlost', (e) => {
                    alert('WebGL context lost. Reload the page to recover.');
                    e.preventDefault();
                }, false);
                return c;
            })(),
            print:    (...args) => console.log(...args),
            printErr: (...args) => console.error(...args),
            setStatus: () => {},
            monitorRunDependencies: () => {}
        };
        window.onerror = () => {};
    </script>

    <script async type="text/javascript" src="@SFML_EMBED_JS@"></script>
</body>
</html>
